{
  "$description": "VibeXP / shaharia-lab design tokens — shadcn default theme, neutral base, OKLCH. Machine-readable mirror of tokens/tokens.css for Figma, codegen and non-CSS consumers.",
  "version": "0.7.1",
  "radius": {
    "base": "0.625rem",
    "sm": "calc(0.625rem - 4px)",
    "md": "calc(0.625rem - 2px)",
    "lg": "0.625rem",
    "xl": "calc(0.625rem + 4px)"
  },
  "shadow": {
    "sm": "0 1px 2px 0 rgb(0 0 0 / 0.05)",
    "md": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)",
    "lg": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)"
  },
  "space": {
    "1": "0.25rem",
    "2": "0.5rem",
    "3": "0.75rem",
    "4": "1rem",
    "6": "1.5rem",
    "8": "2rem",
    "12": "3rem"
  },
  "brand": {
    "DEFAULT": "var(--primary)",
    "foreground": "var(--primary-foreground)",
    "muted": "var(--accent)",
    "ring": "var(--ring)"
  },
  "font": {
    "system": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif",
    "inter": "'Inter', system-ui, Avenir, Helvetica, Arial, sans-serif",
    "poppins": "'Poppins', Inter, system-ui, Avenir, Helvetica, Arial, sans-serif",
    "mono": "ui-monospace, 'SFMono-Regular', 'JetBrains Mono', 'Menlo', 'Consolas', monospace"
  },
  "text": {
    "xs":   { "size": "0.75rem",  "lineHeight": "1rem" },
    "sm":   { "size": "0.875rem", "lineHeight": "1.25rem" },
    "base": { "size": "1rem",     "lineHeight": "1.5rem" },
    "lg":   { "size": "1.125rem", "lineHeight": "1.75rem" },
    "xl":   { "size": "1.25rem",  "lineHeight": "1.75rem" },
    "2xl":  { "size": "1.5rem",   "lineHeight": "2rem" },
    "3xl":  { "size": "1.875rem", "lineHeight": "2.25rem" },
    "4xl":  { "size": "2.25rem",  "lineHeight": "2.5rem" },
    "5xl":  { "size": "3rem",     "lineHeight": "1.08" },
    "6xl":  { "size": "3.75rem",  "lineHeight": "1.05" },
    "7xl":  { "size": "4.5rem",   "lineHeight": "1" }
  },
  "textFluid": {
    "display": "clamp(2.25rem, 1.6rem + 2.7vw, 3.75rem)",
    "title":   "clamp(2.25rem, 1.92rem + 1.35vw, 3rem)",
    "section": "clamp(1.875rem, 1.38rem + 2.02vw, 3rem)",
    "stat":    "clamp(1.875rem, 1.71rem + 0.67vw, 2.25rem)",
    "lead":    "clamp(1.125rem, 1.07rem + 0.22vw, 1.25rem)"
  },
  "fontWeight": {
    "normal": 400,
    "medium": 500,
    "semibold": 600,
    "bold": 700
  },
  "tracking": {
    "tighter": "-0.03em",
    "tight": "-0.018em",
    "normal": "0em",
    "wide": "0.02em",
    "wider": "0.06em"
  },
  "type": {
    "display":    { "size": "var(--text-fluid-display)", "lineHeight": "1.05", "weight": 700, "tracking": "-0.03em" },
    "title":      { "size": "var(--text-fluid-title)",   "lineHeight": "1.1",  "weight": 700, "tracking": "-0.018em" },
    "section":    { "size": "var(--text-fluid-section)", "lineHeight": "1.1",  "weight": 700, "tracking": "-0.018em" },
    "heading":    { "size": "var(--text-2xl)", "lineHeight": "var(--text-2xl-lh)", "weight": 700, "tracking": "-0.018em" },
    "card-title": { "size": "var(--text-xl)",  "lineHeight": "var(--text-xl-lh)",  "weight": 600, "tracking": "-0.018em" },
    "stat":       { "size": "var(--text-fluid-stat)", "lineHeight": "1.1", "weight": 700, "tracking": "-0.018em", "numeric": "tabular-nums" },
    "lead":       { "size": "var(--text-fluid-lead)", "lineHeight": "1.6", "weight": 400, "color": "var(--muted-foreground)" },
    "body":       { "size": "var(--text-base)", "lineHeight": "1.6", "weight": 400 },
    "body-sm":    { "size": "var(--text-sm)",   "lineHeight": "1.5", "weight": 400 },
    "label":      { "size": "var(--text-sm)",   "lineHeight": "var(--text-sm-lh)", "weight": 500, "tracking": "0em" },
    "caption":    { "size": "var(--text-sm)",   "lineHeight": "1.5", "weight": 400, "color": "var(--muted-foreground)" },
    "overline":   { "size": "var(--text-xs)",   "lineHeight": "var(--text-xs-lh)", "weight": 600, "tracking": "0.06em", "transform": "uppercase" },
    "code":       { "size": "var(--text-sm)",   "lineHeight": "var(--text-sm-lh)", "weight": 400, "font": "var(--font-mono)" }
  },
